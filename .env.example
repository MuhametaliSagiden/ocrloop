# Telegram bot token from @BotFather
BOT_TOKEN=

# Optional: recognition backend. "tesseract" (default, lightweight) or
# "easyocr" (heavier, requires `pip install easyocr`; better script handling
# on noisy Russian screenshots).
OCR_ENGINE=tesseract

# Optional: language packs, default is "rus+eng".
# Codes are Tesseract-style (e.g. "rus+eng+deu") and auto-mapped to
# ISO-639-1 for EasyOCR.
OCR_LANGS=rus+eng

# Optional: time (seconds) to wait after the first photo of an album before
# treating the album as complete and starting OCR.
ALBUM_LATENCY=1.2
